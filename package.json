{
  "name": "cardcount",
  "version": "1.0.0",
  "description": "Quiddler card game scorer with vision API",
  "type": "module",
  "scripts": {
    "start": "node scripts/start.js",
    "dev": "concurrently \"npm run proxy\" \"vite --host\"",
    "proxy": "node proxy.js",
    "build": "tsc && vite build",
    "preview": "vite preview --host",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
